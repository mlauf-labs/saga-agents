# saga-agents environment template
# Copy to .env and fill in the values marked with ← CHANGE

# ── Saga MCP server ───────────────────────────────────────────────────────────
SAGA_MCP_URL=http://localhost:8100/mcp
SAGA_MCP_TOKEN=changeme                  # ← CHANGE: must match SAGA_API_TOKENS

# ── LLM (Ollama) ─────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
AGENTS_DEFAULT_MODEL=llama3.1:8b

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SAGA_EVENT_CHANNEL=saga.events

# ── Langfuse tracing (optional — leave blank to disable) ─────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── External API token ────────────────────────────────────────────────────────
AGENTS_EXTERNAL_TOKEN=changeme           # ← CHANGE: used to protect /triggers endpoints

# ── Network ───────────────────────────────────────────────────────────────────
AGENTS_PORT=8099
